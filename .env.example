# Datatalk V2 — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required: At least one LLM API key (Anthropic or OpenAI).
# Everything else has sensible defaults for local development.

# =============================================================================
# LLM API Keys (at least one required)
# =============================================================================

# Anthropic (Claude) — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT-4o) — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# PostgreSQL
# =============================================================================
# Single Postgres instance serves both campaign finance data and FerretDB
# (LibreChat's document store). Uses the postgres-documentdb image which
# includes the DocumentDB extension required by FerretDB 2.x.

POSTGRES_USER=datatalk
POSTGRES_PASSWORD=datatalk_dev
POSTGRES_DB=datatalk
POSTGRES_PORT=5432

# =============================================================================
# FerretDB
# =============================================================================
# MongoDB-compatible proxy that stores data in PostgreSQL.
# LibreChat connects to this as if it were MongoDB.

FERRETDB_PORT=27017

# =============================================================================
# Redis
# =============================================================================
# Session cache and rate limiting for LibreChat.

REDIS_PORT=6379

# =============================================================================
# MeiliSearch
# =============================================================================
# Full-text search for LibreChat conversations.

MEILI_MASTER_KEY=datatalk_meili_dev_key
MEILI_PORT=7700

# =============================================================================
# LibreChat
# =============================================================================

LIBRECHAT_PORT=3080

# Encryption keys for stored credentials. Generate your own for production:
#   openssl rand -hex 32  (for CREDS_KEY, JWT_SECRET, JWT_REFRESH_SECRET)
#   openssl rand -hex 16  (for CREDS_IV)
CREDS_KEY=f34be427ebb29de8d88c107a71546019685ed8b241d8f2ed00c3df97ad2566f0
CREDS_IV=e2341419ec3dd3d19b13a1a87fafcbfb
JWT_SECRET=16f8c0ef4a5d391b26034086c628469d3f9f497f08163ab9b40137092f2909ef
JWT_REFRESH_SECRET=eaa5191d9c2f78aac2e4e12e87bfb45e42289c9086ab8e5671a10e5b41487a76
