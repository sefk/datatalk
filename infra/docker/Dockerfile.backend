# Datatalk MCP Server — Development Dockerfile
#
# Builds the Python backend and runs the MCP server with SSE transport.
# This is for local development, not production.
#
# Build context should be the repo root so we can access backend/ and agent/.
#
# Usage:
#   docker build -f infra/docker/Dockerfile.backend -t datatalk-mcp-server .
#   docker run -p 8080:8080 datatalk-mcp-server

FROM python:3.12-slim

# Install system dependencies needed by psycopg2, etc.
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc libpq-dev git \
    && rm -rf /var/lib/apt/lists/*

# Install uv for fast dependency management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set working directory
WORKDIR /app

# Install V1 agent dependencies (subset — excludes chainlit, not needed for MCP)
COPY infra/docker/requirements-mcp.txt ./
RUN uv pip install --system -r requirements-mcp.txt

# Copy backend source and install the backend package
COPY backend/ ./backend/
RUN uv pip install --system -e ./backend/

# Copy V1 agent code (needed by the query tool's V1 bridge)
COPY agent/ ./agent/

# Install chainlit stub (V1 imports chainlit but MCP server doesn't use the UI)
COPY infra/docker/chainlit_stub.py /usr/local/lib/python3.12/site-packages/chainlit/__init__.py

# The MCP server listens on port 8080
EXPOSE 8080

# Health check: the SSE endpoint should respond
HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8080/sse')" || exit 1

# Working directory must be agent/ so chainlite finds llm_config.yaml on import
WORKDIR /app/agent

# Run the MCP server with SSE transport, bound to all interfaces
CMD ["python", "-m", "datatalk.mcp_server", "--transport", "sse", "--host", "0.0.0.0", "--port", "8080"]
